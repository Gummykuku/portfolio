							<div class="skill-item">Usability Testing</div>
							<div class="skill-item">Heuristic Evaluation</div>
							<div class="skill-item">A/B Testing</div>
							<div class="skill-item">Card Sorting and Tree Testing</div>
							<div class="skill-item">Competitive Analysis</div>
							<div class="skill-item">Journey Mapping</div>
							<div class="skill-item">Personas and Jobs-to-be-Done</div>
							<div class="skill-item">Analytics and Data Synthesis</div>
						</div>
					</div>
