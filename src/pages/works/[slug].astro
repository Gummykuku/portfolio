---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map(project => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, category, year, color, url, tags } = project.data;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} — June`} description={description} />
	</head>
	<body>
		<div class="cursor" id="cursor"></div>
		<div class="cursor-ring" id="ring"></div>

		<Header />

		<main>
			<div class="case-header">
				<a href="/works" class="back">← All work</a>

				<div class="case-meta">
					<span class="case-category">{category}</span>
					<span class="case-year">{year}</span>
				</div>

				<h1>{title}</h1>
				<p class="case-desc">{description}</p>

				{url && (
					<a href={url} target="_blank" rel="noopener" class="case-link">
						View live project ↗
					</a>
				)}

				<div class="case-tags">
					{tags.map(tag => <span class="tag">{tag}</span>)}
				</div>
			</div>

			<div
				class="case-hero"
				style={`background-color: ${color ?? '#F2EDE7'}`}
			/>

			<div class="case-body prose">
				<Content />
			</div>

			<div class="case-footer">
				<a href="/works" class="back">← Back to all work</a>
			</div>
		</main>

		<Footer />

		<script>
			const cursor = document.getElementById('cursor') as HTMLElement;
			const ring   = document.getElementById('ring') as HTMLElement;
			document.body.style.cursor = 'none';
			document.addEventListener('mousemove', e => {
				cursor.style.left = e.clientX + 'px'; cursor.style.top = e.clientY + 'px';
				ring.style.left   = e.clientX + 'px'; ring.style.top   = e.clientY + 'px';
			});
			document.querySelectorAll<HTMLElement>('a').forEach(el => {
				el.addEventListener('mouseenter', () => { cursor.style.width='18px'; cursor.style.height='18px'; cursor.style.opacity='0.5'; ring.style.width='52px'; ring.style.height='52px'; });
				el.addEventListener('mouseleave', () => { cursor.style.width='8px';  cursor.style.height='8px';  cursor.style.opacity='1';   ring.style.width='32px'; ring.style.height='32px'; });
			});
		</script>
	</body>
</html>

<style>
	main { padding-top: 7rem; }

	.case-header {
		padding: 4rem 3.5rem 3rem;
		border-bottom: 1px solid var(--border);
		max-width: 860px;
		opacity: 0;
		animation: fadeUp .9s cubic-bezier(.16,1,.3,1) .4s forwards;
	}
	.back {
		display: inline-block;
		font-size: 1.1rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: 2.5rem;
		transition: color .2s;
	}
	.back:hover { color: var(--accent); }
	.case-meta {
		display: flex;
		gap: 1.5rem;
		align-items: center;
		margin-bottom: 1.25rem;
	}
	.case-category {
		font-size: 1.1rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent);
	}
	.case-year {
		font-size: 1.1rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted);
	}
	h1 {
		font-family: var(--font-display);
		font-weight: 300;
		font-size: clamp(2rem, 5vw, 3.8rem);
		line-height: 1.1;
		letter-spacing: 0.01em;
		margin-bottom: 1.25rem;
	}
	.case-desc {
		font-size: 1.1rem;
		color: var(--muted);
		line-height: 1.8;
		max-width: 58ch;
		margin-bottom: 1.5rem;
	}
	.case-link {
		display: inline-block;
		font-size: 1.1rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
		border-bottom: 1px solid var(--accent);
		padding-bottom: 0.1rem;
		margin-bottom: 1.5rem;
		transition: opacity .2s;
	}
	.case-link:hover { opacity: 0.7; }
	.case-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
	.tag { font-size: 1.1rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); border: 1px solid var(--border); padding: 0.18rem 0.5rem; }

	.case-hero {
		width: 100%;
		aspect-ratio: 16 / 6;
	}

	.case-body {
		padding: 4rem 3.5rem;
		max-width: 720px;
	}

	.case-footer {
		padding: 2rem 3.5rem 4rem;
		border-top: 1px solid var(--border);
	}

	@media (max-width: 700px) {
		.case-header { padding: 3rem 1.5rem 2.5rem; }
		.case-body { padding: 3rem 1.5rem; }
		.case-footer { padding: 1.5rem 1.5rem 3rem; }
	}
</style>
