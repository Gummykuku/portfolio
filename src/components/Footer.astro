---
const year = new Date().getFullYear();
---

<footer id="site-footer">
	<canvas id="footer-canvas"></canvas>

	<div class="footer-inner reveal">
		<div class="footer-eyebrow">
			<div class="footer-eyebrow-line"></div>
			<span>Get in touch</span>
		</div>

		<h2
			class="footer-heading"
			data-text="Let's work together."
		>Let's work together.</h2>

		<div class="footer-links">
			<a href="mailto:juef7385@gmail.com" class="footer-link">juef7385@gmail.com</a>
			<a href="https://www.linkedin.com/in/june-fang-15ab46210" target="_blank" rel="noopener noreferrer" class="footer-link">LinkedIn ↗</a>
		</div>

		<div class="footer-bottom">
			<span>© {year} June</span>
			<span class="footer-mid">UX &amp; Product Design</span>
		</div>
	</div>
</footer>

<style>
	@keyframes bgShift {
		0%   { background-position:   0%  20%; }
		20%  { background-position:  80%  60%; }
		40%  { background-position: 100%  10%; }
		60%  { background-position:  30%  90%; }
		80%  { background-position:  60%  40%; }
		100% { background-position:   0%  20%; }
	}

	footer {
		position: relative;
		overflow: hidden;
		/* asymmetric sunset — no mirror, no hard seam */
		background: linear-gradient(115deg,
			#fff3e0  0%,
			#ffd58a 12%,
			#ffb05a 24%,
			#FB9966 36%,
			#f07232 47%,
			#d94520 58%,
			#c03a18 65%,
			#e06828 74%,
			#FB9966 83%,
			#ffcc7a 92%,
			#ffecd0 100%
		);
		background-size: 300% 300%;
		animation: bgShift 40s ease infinite;
		border-top: none;
		padding: 4rem 7rem 2.5rem;
	}

	/* ── Ripple canvas ── */
	#footer-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	/* ── Layout ── */
	.footer-inner {
		position: relative;
		display: flex;
		flex-direction: column;
	}

	/* ── Eyebrow ── */
	.footer-eyebrow {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}
	.footer-eyebrow-line {
		width: 28px;
		height: 1px;
		background: rgba(80, 30, 5, 0.5);
	}
	.footer-eyebrow span {
		font-size: 0.75rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(80, 30, 5, 0.65);
	}

	/* ── Heading ── */
	.footer-heading {
		position: relative;
		font-family: var(--font-display);
		font-weight: 300;
		font-size: clamp(2.8rem, 6vw, 5.5rem);
		line-height: 0.97;
		letter-spacing: -0.025em;
		color: var(--text);
		margin: 0 0 2rem;
		cursor: default;
		display: inline-block;
		align-self: flex-start;   /* shrink to text width, not full row */
	}
	/* hover: white wipes in from left */
	.footer-heading::after {
		content: attr(data-text);
		position: absolute;
		inset: 0;
		color: #fff;
		clip-path: inset(0 100% 0 0);
		transition: clip-path 6s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.footer-heading:hover::after {
		clip-path: inset(0 0% 0 0);
	}

	/* ── Links ── */
	.footer-links {
		display: flex;
		gap: 3rem;
		align-items: center;
		margin-bottom: 2.5rem;
	}
	.footer-link {
		position: relative;
		color: var(--text);
		text-decoration: none;
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding-bottom: 4px;
		transition: color 0.25s;
	}
	.footer-link::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 1px;
		background: var(--text);
		transform: scaleX(0);
		transform-origin: center;
		transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.footer-link:hover::after { transform: scaleX(1); }

	/* ── Bottom strip ── */
	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 2rem;
		border-top: 1px solid rgba(80, 30, 5, 0.2);
		font-size: 0.75rem;
		letter-spacing: 0.13em;
		text-transform: uppercase;
		color: rgba(80, 30, 5, 0.55);
	}
	.footer-mid {
		font-style: italic;
		font-family: var(--font-display);
		font-size: 0.75rem;
		letter-spacing: 0.04em;
		text-transform: none;
	}

	/* ── Responsive ── */
	@media (max-width: 900px) {
		footer { padding: 3rem 3rem 2rem; }
	}
	@media (max-width: 600px) {
		footer { padding: 2.5rem 1.5rem 1.5rem; }
		.footer-links { flex-direction: column; gap: 1.25rem; }
		.footer-mid { display: none; }
	}
</style>

<script>
	const footer = document.getElementById('site-footer') as HTMLElement;
	const canvas = document.getElementById('footer-canvas') as HTMLCanvasElement;
	const ctx    = canvas.getContext('2d')!;

	function resize() {
		canvas.width  = footer.offsetWidth;
		canvas.height = footer.offsetHeight;
	}
	resize();
	new ResizeObserver(resize).observe(footer);

	/* ── Ripple rings ── */
	interface Ring {
		x: number; y: number;
		r: number; maxR: number;
		delay: number;
		/* distortion TARGET — ring starts as circle, morphs toward this */
		dstX: number; dstY: number;
		speed: number;
		opacityMax: number;
	}

	const rng   = () => Math.random();
	const rings: Ring[] = [];
	let lastX = -999, lastY = -999;
	const MIN_DIST = 55;

	footer.addEventListener('mousemove', e => {
		const rect = footer.getBoundingClientRect();
		const x = e.clientX - rect.left;
		const y = e.clientY - rect.top;

		if (Math.hypot(x - lastX, y - lastY) > MIN_DIST) {
			const count = 1 + Math.floor(rng() * 3);
			for (let i = 0; i < count; i++) {
				rings.push({
					x: x + (rng() - 0.5) * 10,
					y: y + (rng() - 0.5) * 10,
					r: 0,
					maxR: 50 + rng() * 120,           /* 50–170 px, irregular spacing */
					delay: Math.floor(rng() * 28),     /* 0–27 frames, uneven gaps */
					/* target ellipse — one axis stretches, other compresses */
					dstX: 0.72 + rng() * 0.56,        /* 0.72–1.28 */
					dstY: 0.72 + rng() * 0.56,
					speed: 0.30 + rng() * 0.25,
					opacityMax: 0.18 + rng() * 0.16,
				});
			}
			lastX = x; lastY = y;
		}
	});

	footer.addEventListener('mouseleave', () => { lastX = -999; lastY = -999; });

	(function tick() {
		ctx.clearRect(0, 0, canvas.width, canvas.height);

		for (let i = rings.length - 1; i >= 0; i--) {
			const ring = rings[i];

			if (ring.delay > 0) { ring.delay--; continue; }

			const t = ring.r / ring.maxR;             /* 0 → 1 */
			ring.r += ring.speed * (1 - t * 0.45);

			if (ring.r >= ring.maxR) { rings.splice(i, 1); continue; }

			/* circle at t=0, morphs toward target ellipse as t→1 */
			const sx = 1 + (ring.dstX - 1) * t;
			const sy = 1 + (ring.dstY - 1) * t;

			const opacity = (1 - t) * ring.opacityMax;
			const lw      = 0.8 + (1 - t) * 1.2;

			ctx.save();
			ctx.translate(ring.x, ring.y);
			ctx.scale(sx, sy);
			ctx.beginPath();
			ctx.arc(0, 0, ring.r, 0, Math.PI * 2);
			ctx.restore();
			ctx.strokeStyle = `rgba(255, 255, 255, ${opacity})`;
			ctx.lineWidth   = lw;
			ctx.stroke();
		}

		requestAnimationFrame(tick);
	})();
</script>
