---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Work — June" description="UX and product design case studies by June." />
	</head>
	<body>
		<div class="cursor" id="cursor"></div>
		<div class="cursor-ring" id="ring"></div>

		<Header />

		<main>
			<div class="page-header">
				<div class="header-eyebrow">
					<div class="eyebrow-line"></div>
					<span>Selected Work</span>
				</div>
				<h1>Case Studies</h1>
			</div>

			<div class="section-head">
				<span class="section-title">All Projects</span>
				<span class="section-num">{projects.length} projects</span>
			</div>

			<div class="projects-grid">
				{projects.map((project, i) => (
					<div class={`project-card${project.data.comingSoon ? ' coming-soon' : ''}`}>
						<div class="project-card-top">
							<span class="project-card-num">0{i + 1}</span>
							<div class="project-card-top-right">
								{project.data.badge && (
									<span class="ai-badge"><span class="ai-badge-dot"></span>{project.data.badge}</span>
								)}
								{project.data.comingSoon ? (
									<span class="soon-badge">Coming Soon</span>
								) : (
									<a href={`/works/${project.id}`} class="project-card-arrow">↗</a>
								)}
							</div>
						</div>
						<div class="project-card-type">{project.data.category}</div>
						<div class="project-card-title">{project.data.title}</div>
						<div class="project-card-desc">{project.data.description}</div>
						<div class="project-card-tags">
							{project.data.tags.map(tag => <span class="tag">{tag}</span>)}
						</div>
					</div>
				))}
			</div>
		</main>

		<Footer />

		<script>
			const cursor = document.getElementById('cursor') as HTMLElement;
			const ring   = document.getElementById('ring') as HTMLElement;
			document.body.style.cursor = 'none';
			document.addEventListener('mousemove', e => {
				cursor.style.left = e.clientX + 'px'; cursor.style.top = e.clientY + 'px';
				ring.style.left   = e.clientX + 'px'; ring.style.top   = e.clientY + 'px';
			});
			document.querySelectorAll<HTMLElement>('a, .project-card').forEach(el => {
				el.addEventListener('mouseenter', () => { cursor.style.width='18px'; cursor.style.height='18px'; cursor.style.opacity='0.5'; ring.style.width='52px'; ring.style.height='52px'; });
				el.addEventListener('mouseleave', () => { cursor.style.width='8px';  cursor.style.height='8px';  cursor.style.opacity='1';   ring.style.width='32px'; ring.style.height='32px'; });
			});
		</script>
	</body>
</html>

<style>
	main { padding-top: 7rem; }

	.page-header {
		padding: 4rem 7rem 2.5rem;
		border-bottom: 1px solid var(--border);
		opacity: 0;
		animation: fadeUp .9s cubic-bezier(.16,1,.3,1) .4s forwards;
	}
	.header-eyebrow {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}
	.eyebrow-line { width: 28px; height: 1px; background: var(--accent); }
	.header-eyebrow span {
		font-size: 0.82rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent);
	}
	h1 {
		font-family: var(--font-display);
		font-weight: 300;
		font-size: clamp(2.5rem, 6vw, 5rem);
		letter-spacing: 0.01em;
		color: var(--text);
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		border-bottom: 1px solid var(--border);
		padding: 1.2rem 7rem;
	}
	.section-title {
		font-family: var(--font-display);
		font-weight: 400;
		font-size: 0.92rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--muted);
	}
	.section-num {
		font-family: var(--font-display);
		font-size: 0.92rem;
		color: var(--muted);
		font-style: italic;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1px;
		background: var(--border);
		margin-top: 1px;
	}
	.project-card {
		background: var(--bg);
		padding: 2.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
		cursor: none;
		transition: background .3s;
	}
	.project-card:hover { background: var(--bg2); }
	.project-card.coming-soon { opacity: 0.6; }
	.project-card.coming-soon .project-card-title { font-style: italic; }
	.project-card-top { display: flex; justify-content: space-between; align-items: flex-start; }
	.project-card-top-right { display: flex; align-items: center; gap: .6rem; }
	.project-card-num { font-size: 0.82rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }
	.project-card-arrow {
		width: 28px; height: 28px;
		border: 1px solid var(--border);
		border-radius: 50%;
		display: flex; align-items: center; justify-content: center;
		font-size: 0.9rem; color: var(--muted);
		text-decoration: none; cursor: none;
		transition: border-color .3s, color .3s, transform .3s;
	}
	.project-card:hover .project-card-arrow { border-color: var(--accent); color: var(--accent); transform: rotate(45deg); }
	.soon-badge { font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); border: 1px solid var(--border); padding: 0.22rem 0.6rem; }

	/* AI Agent badge */
	.ai-badge {
		display: inline-flex; align-items: center; gap: .4rem;
		background: rgba(251,153,102,.1);
		border: 1px solid rgba(251,153,102,.35);
		border-radius: 2rem;
		padding: .22rem .75rem;
		font-size: .68rem; letter-spacing: .12em; text-transform: uppercase;
		color: var(--accent);
	}
	.ai-badge-dot {
		width: 5px; height: 5px;
		background: var(--accent);
		border-radius: 50%;
		animation: pulse 2s ease-in-out infinite;
	}
	@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.8)} }

	.project-card-type { font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); }
	.project-card-title {
		font-family: var(--font-display);
		font-weight: 400;
		font-size: 1.4rem;
		line-height: 1.25;
		color: var(--text);
		transition: color .3s;
	}
	.project-card:hover .project-card-title { color: var(--accent); }
	.project-card-desc { font-size: 0.95rem; line-height: 1.8; color: var(--muted); }
	.project-card-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: auto; }
	.tag { font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); border: 1px solid var(--border); padding: 0.22rem 0.6rem; }

	@keyframes fadeUp { from { opacity:0; transform:translateY(24px) } to { opacity:1; transform:translateY(0) } }

	@media (max-width: 700px) {
		.page-header { padding: 3rem 1.5rem 2rem; }
		.section-head { padding: 1rem 1.5rem; }
		.projects-grid { grid-template-columns: 1fr; }
		.project-card { padding: 2rem 1.5rem; }
	}
</style>
