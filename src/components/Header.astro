<nav>
	<div class="nav-left">
		<a href="/" class="nav-logo"><img src="/images/nannan.png" alt="June" class="nav-logo-img" /></a>
	</div>
	<ul class="nav-links">
		<li><a href="/about">About</a></li>
		<li><a href="https://drive.google.com/file/d/1CBR1WHEhr0TS7955NZbYLYaMJSZdkJjY/view" target="_blank" rel="noopener noreferrer">Resume</a></li>
	</ul>
</nav>

<style>
	nav {
		position: fixed;
		top: 0; left: 0; right: 0;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 7rem;
		z-index: 100;
		background: rgba(248, 245, 241, 0.88);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		border-bottom: 1px solid var(--border);
		opacity: 0;
		animation: fadeDown .8s ease .2s forwards;
	}
	.nav-left { display: flex; align-items: center; }
	.nav-logo-img { height: 40px; width: auto; display: block; }
	.nav-logo {
		font-family: var(--font-display);
		font-weight: 400;
		font-size: 1.15rem;
		letter-spacing: 0.06em;
		color: var(--text);
	}
	.nav-logo em {
		font-style: italic;
		color: var(--accent);
	}
	.nav-links {
		display: flex;
		gap: 2.5rem;
		list-style: none;
	}
	.nav-links a {
		font-size: 0.82rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted);
		text-decoration: none;
		transition: color .25s;
	}
	.nav-links a:hover { color: var(--accent); }
	@media (max-width: 1100px) {
		nav { padding: 1rem 3rem; }
	}
	@media (max-width: 900px) {
		nav { padding: 1rem 2rem; }
	}
	@media (max-width: 700px) {
		nav { padding: .8rem 1.5rem; }
		.nav-links { gap: 1.5rem; }
	}
</style>
