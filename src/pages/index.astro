---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="June — UX & Product Designer" description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="cursor" id="cursor"></div>
		<div class="cursor-ring" id="ring"></div>

		<Header />

		<!-- ─── HERO ─── -->
		<section class="hero">
			<div class="hero-main">
				<div class="hero-intro">
					<p class="hero-line-1">Hi, I am <em>June.</em></p>
					<p class="hero-line-2">I am a designer and researcher at UC Berkeley, working at the intersection of AI and human experience. Complexity is a given. Clarity is the job.</p>
					<p class="hero-bio">UX Research / AI Interfaces / End to End Design</p>
				</div>

				<div class="hero-actions">
					<a href="#works" class="btn btn-fill">View Work ↓</a>
					<a href="/about" class="btn btn-outline">About me →</a>
				</div>

			</div>
		</section>

		<!-- ─── SKILL TICKER ─── -->
		<div class="ticker-wrap" id="ticker-wrap">
			<div class="ticker-track" id="ticker-track">
				<div class="ticker-seg">
					<span class="t-word">WIREFRAMING</span><span class="t-dot">·</span>
					<span class="t-word t-hi">VISUAL DESIGN</span><span class="t-dot">·</span>
					<span class="t-word">DESIGN SYSTEMS</span><span class="t-dot">·</span>
					<span class="t-word t-hi">INFORMATION ARCHITECTURE</span><span class="t-dot">·</span>
					<span class="t-word">ACCESSIBILITY WCAG</span><span class="t-dot">·</span>
					<span class="t-word t-hi">HEURISTIC EVALUATION</span><span class="t-dot">·</span>
					<span class="t-word">CARD SORTING</span><span class="t-dot">·</span>
					<span class="t-word t-hi">USABILITY TESTING</span><span class="t-dot">·</span>
					<span class="t-word">USER INTERVIEWS</span><span class="t-dot">·</span>
					<span class="t-word t-hi">PROTOTYPING</span><span class="t-dot">·</span>
					<span class="t-word">INTERACTION DESIGN</span><span class="t-dot">·</span>
					<span class="t-word t-hi">AI UX DESIGN</span><span class="t-dot">·</span>
					<span class="t-word">JOURNEY MAPPING</span><span class="t-dot">·</span>
					<span class="t-word t-hi">PRODUCT STRATEGY</span><span class="t-dot">·</span>
					<span class="t-word">RESEARCH SYNTHESIS</span><span class="t-dot">·</span>
					<span class="t-word t-hi">RESPONSIVE DESIGN</span><span class="t-dot">·</span>
				</div>
				<div class="ticker-seg" aria-hidden="true">
					<span class="t-word">WIREFRAMING</span><span class="t-dot">·</span>
					<span class="t-word t-hi">VISUAL DESIGN</span><span class="t-dot">·</span>
					<span class="t-word">DESIGN SYSTEMS</span><span class="t-dot">·</span>
					<span class="t-word t-hi">INFORMATION ARCHITECTURE</span><span class="t-dot">·</span>
					<span class="t-word">ACCESSIBILITY WCAG</span><span class="t-dot">·</span>
					<span class="t-word t-hi">HEURISTIC EVALUATION</span><span class="t-dot">·</span>
					<span class="t-word">CARD SORTING</span><span class="t-dot">·</span>
					<span class="t-word t-hi">USABILITY TESTING</span><span class="t-dot">·</span>
					<span class="t-word">USER INTERVIEWS</span><span class="t-dot">·</span>
					<span class="t-word t-hi">PROTOTYPING</span><span class="t-dot">·</span>
					<span class="t-word">INTERACTION DESIGN</span><span class="t-dot">·</span>
					<span class="t-word t-hi">AI UX DESIGN</span><span class="t-dot">·</span>
					<span class="t-word">JOURNEY MAPPING</span><span class="t-dot">·</span>
					<span class="t-word t-hi">PRODUCT STRATEGY</span><span class="t-dot">·</span>
					<span class="t-word">RESEARCH SYNTHESIS</span><span class="t-dot">·</span>
					<span class="t-word t-hi">RESPONSIVE DESIGN</span><span class="t-dot">·</span>
				</div>
			</div>
		</div>

		<!-- ─── PROJECTS ─── -->
		<section class="section" id="works">
			<div class="section-head">
				<span class="section-title">Selected Work</span>
				<span class="section-num">{projects.length} projects</span>
			</div>
			<div class="proj-list" id="projList">
				{projects.map((project, i) => (
					project.data.comingSoon ? (
						<div class="proj-row proj-row-soon" style={`--i:${i}`}>
							<span class="proj-num">0{i + 1}</span>
							<div class="proj-info">
								<div class="proj-title-row">
									<span class="proj-title">{project.data.title}</span>
									<span class="proj-soon-tag">Soon</span>
								</div>
								<p class="proj-desc">{project.data.description}</p>
							</div>
							<div class="proj-row-right">
								<div class="proj-tags">
									{project.data.tags.map(tag => <span class="proj-tag">{tag}</span>)}
								</div>
							</div>
						</div>
					) : (
						<a href={`/works/${project.id}`} class="proj-row" data-img={project.data.image} style={`--i:${i}`}>
							<span class="proj-num">0{i + 1}</span>
							<div class="proj-info">
								<div class="proj-title-row">
									<span class="proj-title">{project.data.title}</span>
									{project.data.badge && (
										<span class="proj-badge">
											<span class="proj-badge-dot"></span>{project.data.badge}
										</span>
									)}
								</div>
								<p class="proj-desc">{project.data.description}</p>
							</div>
							<div class="proj-row-right">
								<div class="proj-tags">
									{project.data.tags.map(tag => <span class="proj-tag">{tag}</span>)}
								</div>
								<span class="proj-arrow">↗</span>
							</div>
						</a>
					)
				))}
			</div>
		</section>

		<Footer />

		<script>
			// Cursor
			const cursor = document.getElementById('cursor') as HTMLElement;
			const ring   = document.getElementById('ring') as HTMLElement;
			document.body.style.cursor = 'none';

			document.addEventListener('mousemove', e => {
				cursor.style.left = e.clientX + 'px';
				cursor.style.top  = e.clientY + 'px';
				ring.style.left   = e.clientX + 'px';
				ring.style.top    = e.clientY + 'px';
			});

			document.querySelectorAll<HTMLElement>('a, .proj-row').forEach(el => {
				el.addEventListener('mouseenter', () => {
					cursor.style.width   = '18px';
					cursor.style.height  = '18px';
					cursor.style.opacity = '0.5';
					ring.style.width     = '52px';
					ring.style.height    = '52px';
				});
				el.addEventListener('mouseleave', () => {
					cursor.style.width   = '8px';
					cursor.style.height  = '8px';
					cursor.style.opacity = '1';
					ring.style.width     = '32px';
					ring.style.height    = '32px';
				});
			});

			// Scroll reveal — rows stagger in individually
			const obs = new IntersectionObserver(entries => {
				entries.forEach(e => {
					if (e.isIntersecting) {
						requestAnimationFrame(() => e.target.classList.add('in'));
						obs.unobserve(e.target);
					}
				});
			}, { threshold: 0.1 });
			document.querySelectorAll('.reveal, .proj-row').forEach(el => obs.observe(el));

			// Project row hover — floating image follows cursor
			const projFloat = document.createElement('div');
			const projFloatImg = document.createElement('img');
			projFloatImg.alt = '';
			Object.assign(projFloatImg.style, { width: '100%', height: 'auto', display: 'block' });
			projFloat.appendChild(projFloatImg);
			Object.assign(projFloat.style, {
				position: 'fixed', top: '0', left: '0',
				width: '300px',
				pointerEvents: 'none',
				zIndex: '9990',
				borderRadius: '10px',
				overflow: 'hidden',
				opacity: '0',
				transform: 'translate(-50%, -62%) scale(0.9) rotate(-1.5deg)',
				transition: 'opacity 0.3s ease, transform 0.3s cubic-bezier(0.16,1,0.3,1)',
				boxShadow: '0 18px 52px rgba(0,0,0,0.14)',
			});
			document.body.appendChild(projFloat);

			let ptx = 0, pty = 0, pcx = 0, pcy = 0;
			document.querySelectorAll<HTMLElement>('a.proj-row[data-img]').forEach(row => {
				row.addEventListener('mouseenter', () => {
					projFloatImg.src = row.dataset.img!;
					projFloat.style.opacity = '1';
					projFloat.style.transform = 'translate(-50%, -62%) scale(1) rotate(0deg)';
				});
				row.addEventListener('mousemove', e => { ptx = e.clientX; pty = e.clientY; });
				row.addEventListener('mouseleave', () => {
					projFloat.style.opacity = '0';
					projFloat.style.transform = 'translate(-50%, -62%) scale(0.9) rotate(-1.5deg)';
				});
			});
			const lerpP = (a: number, b: number, t: number) => a + (b - a) * t;
			(function projTick() {
				pcx = lerpP(pcx, ptx, 0.1);
				pcy = lerpP(pcy, pty, 0.1);
				projFloat.style.left = pcx + 'px';
				projFloat.style.top  = pcy + 'px';
				requestAnimationFrame(projTick);
			})();

		</script>
	</body>
</html>

<style>
	/* ─── SPACING TOKENS ─── */
	/* Outer gutter: 5rem desktop, 1.5rem mobile                  */
	/* Section vertical: 7rem desktop, 4rem mobile                */
	/* Card inner: 3rem desktop                                    */

	/* ─── HERO ─── */
	.hero {
		height: 100vh;
		display: flex;
		align-items: center;
		padding: 0 7rem;
	}
	.hero-main {
		display: flex;
		flex-direction: column;
		justify-content: center;
		width: 100%;
		gap: 0;                  /* use explicit margins below for fine control */
		opacity: 0;
		animation: fadeUp .9s cubic-bezier(.16,1,.3,1) .5s forwards;
	}

	/* Level 1 — tiny label */
	.hero-eyebrow {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 3rem;    /* large gap before hero text */
	}
	.hero-eyebrow-line { width: 28px; height: 1px; background: var(--accent); }
	.hero-eyebrow span {
		font-size: 0.75rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
	}

	/* Level 2 — dominant text */
	.hero-intro { margin-bottom: 3rem; }
	.hero-line-1 {
		font-family: var(--font-display);
		font-weight: 300;
		font-size: clamp(2.8rem, 6vw, 5.5rem);
		line-height: 1.0;
		letter-spacing: -0.02em;
		color: var(--text);
		margin-bottom: .25em;
	}
	.hero-line-1 em { font-style: italic; color: var(--accent); }
	.hero-line-2 {
		font-family: var(--font-display);
		font-weight: 300;
		font-size: clamp(1.35rem, 2.2vw, 1.9rem);
		line-height: 1.5;
		letter-spacing: -0.01em;
		color: var(--text);
	}
	.hero-bio {
		font-family: var(--font);
		font-size: 1rem;
		line-height: 1.8;
		color: var(--muted);
		margin-top: 2.5rem;
	}

	/* Level 3 — CTA row */
	.hero-actions {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 2rem;              /* horizontal, left-aligned under text */
	}
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		font-family: var(--font);
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		font-weight: 400;
		transition: gap .3s, color .3s, background .3s;
		text-decoration: none;
		white-space: nowrap;
	}
	.btn-fill {
		padding: 1rem 2.2rem;
		background: var(--text);
		color: var(--bg);
	}
	.btn-fill:hover { background: var(--accent); gap: 1.1rem; }
	.btn-outline {
		color: var(--muted);
		border-bottom: 1px solid var(--border);
		padding-bottom: 0.15rem;
	}
	.btn-outline:hover { color: var(--accent); border-color: var(--accent); gap: 1.1rem; }

	/* Hero bar — metadata strip at bottom of hero */
	.hero-bar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 2rem 0;
		border-top: 1px solid var(--border);
		margin-top: 5rem;
		opacity: 0;
		animation: fadeUp .8s ease 1.1s forwards;
	}
	.hero-bar-item { display: flex; flex-direction: column; gap: 0.5rem; }
	.hero-bar-label {
		font-size: 0.75rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--muted);
	}
	.hero-bar-value {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 400;
		color: var(--text);
	}
	.hero-bar-value em { font-style: italic; color: var(--accent); }
	.scroll-hint {
		display: flex;
		align-items: center;
		background: none;
		border: none;
		padding: 0;
		cursor: none;
	}
	.scroll-hint-line {
		width: 1px; height: 32px;
		background: var(--accent);
		animation: pulse-line 2s ease-in-out infinite;
	}

	/* ─── SKILL TICKER ─── */
	.ticker-wrap {
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		overflow: hidden;
		padding: 1.25rem 0;
		opacity: 0;
		animation: fadeUp .8s ease 1s forwards;
		position: relative;
	}
	.ticker-track {
		display: flex;
		width: max-content;
		animation: ticker-scroll 36s linear infinite;
	}
	.ticker-seg {
		display: flex;
		align-items: center;
	}
	.t-word {
		font-size: 0.75rem;
		letter-spacing: .15em;
		text-transform: uppercase;
		color: var(--muted);
		padding: 0 1.4rem;
		white-space: nowrap;
		display: inline-block;
	}
	.t-word.t-hi { color: var(--accent); }
	.t-dot {
		color: var(--accent);
		font-size: 0.75rem;
		flex-shrink: 0;
		opacity: 0.5;
	}
	@keyframes ticker-scroll {
		from { transform: translateX(0); }
		to   { transform: translateX(-50%); }
	}

	/* ─── SECTION SHELL ─── */
	.section { padding: 7rem; scroll-margin-top: 80px; }   /* matches navbar 7rem */

	/* Section label row: tiny uppercase title + count */
	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		border-bottom: 1px solid var(--border);
		padding-bottom: 1.25rem;
		margin-bottom: 0;
	}
	.section-title {
		font-size: 0.75rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--muted);
		font-weight: 400;
	}
	.section-num {
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		color: var(--muted);
		font-style: italic;
		font-family: var(--font-display);
	}

	/* ─── PROJECT LIST ─── */
	.proj-list { margin-top: 0; }

	.proj-row {
		display: grid;
		grid-template-columns: 2.5rem 1fr auto;
		align-items: center;
		gap: 2.5rem;
		padding: 2rem 0;
		border-bottom: 1px solid var(--border);
		text-decoration: none;
		color: inherit;
		cursor: none;
		/* staggered reveal */
		opacity: 0;
		transform: translateY(16px);
		transition:
			opacity  .55s ease         calc(var(--i, 0) * 0.1s + 0.05s),
			transform .55s cubic-bezier(.16,1,.3,1) calc(var(--i, 0) * 0.1s + 0.05s),
			background .25s;
	}
	.proj-row.in            { opacity: 1; transform: translateY(0); }
	.proj-row-soon.in       { opacity: 0.5; }
	.proj-row:first-child   { border-top: 1px solid var(--border); }
	a.proj-row:hover        { background: var(--bg2); }

	.proj-num {
		font-size: 0.75rem;
		letter-spacing: .12em;
		text-transform: uppercase;
		color: var(--muted);
		align-self: start;
		padding-top: .15rem;
		transition: color .25s;
	}
	a.proj-row:hover .proj-num { color: var(--accent); }

	.proj-info { display: flex; flex-direction: column; gap: .45rem; }
	.proj-title-row { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
	.proj-title {
		font-family: var(--font-display);
		font-weight: 300;
		font-size: clamp(1.35rem, 1.8vw, 1.9rem);
		color: var(--text);
		line-height: 1.15;
		transition: color .25s;
	}
	a.proj-row:hover .proj-title { color: var(--accent); }
	.proj-desc { font-size: 1rem; line-height: 1.65; color: var(--muted); max-width: 58ch; }

	.proj-row-right {
		display: flex;
		align-items: center;
		gap: 2rem;
		flex-shrink: 0;
	}
	.proj-tags { display: flex; flex-wrap: wrap; gap: .35rem; justify-content: flex-end; }
	.proj-tag {
		font-size: 0.75rem;
		letter-spacing: .1em;
		text-transform: uppercase;
		color: var(--muted);
		border: 1px solid var(--border);
		padding: .2rem .6rem;
	}
	.proj-arrow {
		font-size: 1.1rem;
		color: var(--muted);
		transition: color .25s, transform .3s cubic-bezier(.16,1,.3,1);
		flex-shrink: 0;
	}
	a.proj-row:hover .proj-arrow { color: var(--accent); transform: rotate(45deg); }

	.proj-soon-tag {
		font-size: 0.75rem;
		letter-spacing: .12em;
		text-transform: uppercase;
		color: var(--muted);
		border: 1px solid var(--border);
		padding: .2rem .6rem;
	}
	.proj-badge {
		display: inline-flex;
		align-items: center;
		gap: .35rem;
		background: rgba(251,153,102,.1);
		border: 1px solid rgba(251,153,102,.35);
		border-radius: 2rem;
		padding: .18rem .65rem;
		font-size: 0.7rem;
		letter-spacing: .1em;
		text-transform: uppercase;
		color: var(--accent);
	}
	.proj-badge-dot {
		width: 5px; height: 5px;
		background: var(--accent);
		border-radius: 50%;
		animation: pulse 2s ease-in-out infinite;
	}
	@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.8)} }


	/* ─── RESPONSIVE ─── */
	@media (max-width: 1100px) {
		.hero { padding: 0 3rem; padding-top: 8rem; }
		.section { padding: 6rem 3rem; }
	}
	@media (max-width: 900px) {
		.hero { padding: 0 2rem; padding-top: 7rem; }
		.section { padding: 5rem 2rem; }
	}
	@media (max-width: 700px) {
		.hero { padding: 0 1.5rem; padding-top: 6.5rem; }
		.hero-actions { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
		.section { padding: 4rem 1.5rem; }
		.ticker-wrap { display: none; }
		.proj-row { grid-template-columns: 2rem 1fr; gap: 1.25rem; }
		.proj-row-right { display: none; }
		.proj-desc { max-width: 100%; }
	}
</style>
