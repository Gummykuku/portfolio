---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title="FFVI Worlds Collide — June" description="Making a Complex Game System Accessible — Redesigning the FFVI Worlds Collide Randomizer." />
</head>
<body>
	<div class="cursor" id="cursor"></div>
	<div class="cursor-ring" id="ring"></div>

	<Header />

	<div class="page-wrapper">

		<!-- ── Side nav ── -->
		<div class="side-nav-col">
			<nav class="side-nav" id="sideNav">
				<div class="side-nav-group">
					<span class="side-nav-label">TL;DR</span>
					<div class="side-nav-rule"></div>
					<a class="side-nav-item active" href="#s-overview">Overview</a>
					<a class="side-nav-item" href="#s-context">Context</a>
					<a class="side-nav-item" href="#s-pain">Pain points</a>
					<a class="side-nav-item" href="#s-solution">Solution</a>
					<div class="side-nav-spacer"></div>
					<span class="side-nav-label">Details</span>
					<div class="side-nav-rule"></div>
					<a class="side-nav-item" href="#s-research">Research</a>
					<a class="side-nav-item" href="#s-complaints">Top 5 complaints</a>
					<a class="side-nav-item" href="#s-designsol">Design Solutions</a>
					<a class="side-nav-item" href="#s-reflection">Reflection</a>
				</div>
			</nav>
		</div>

		<!-- ── Main content ── -->
		<div class="main-content">

			<!-- ① OVERVIEW -->
			<section class="hero" id="s-overview">
				<div class="hero-eyebrow">
					<div class="hero-eyebrow-line"></div>
					<span>Overview</span>
				</div>
				<h1 class="hero-title">Making a Complex Game System <em>Accessible</em></h1>
				<h2 class="hero-subtitle">Redesigning the FFVI Worlds Collide Randomizer</h2>
				<div class="sponsored-badge">Sponsored Project</div>

				<div class="meta-strip">
					<div class="meta-item">
						<span class="label">Role</span>
						<span class="meta-value"><em>UX Lead</em> of 8 UX designers</span>
					</div>
					<div class="meta-item">
						<span class="label">Timeline</span>
						<span class="meta-value">5 Months</span>
					</div>
					<div class="meta-item">
						<span class="label">Period</span>
						<span class="meta-value">Jan 2023 — May 2023</span>
					</div>
					<div class="meta-item">
						<span class="label">Brief</span>
						<span class="meta-value" style="font-size: 1rem;line-height:1.6">Redesigning the FFVI Worlds Collide Randomizer tool for better accessibility.</span>
					</div>
				</div>

				<!-- Before / After -->
				<div class="overview-bfaf">
					<div class="overview-bfaf-cell">
						<span class="bfaf-label">Before</span>
						<p class="impact-bfaf-text">200+ settings with no guidance. New players quit before their first run.</p>
					</div>
					<div class="overview-bfaf-cell">
						<span class="bfaf-label after">After</span>
						<p class="impact-bfaf-text">Character-guided onboarding and a Basic/Advanced mode split so new users could start without understanding everything first.</p>
					</div>
				</div>

				<!-- Overview impact stats -->
				<div class="overview-stats">
					<div class="overview-stats-header">
						<span class="bfaf-label">Impact</span>
						<p class="stats-note">Measured via usability testing with community members across skill levels.</p>
					</div>
					<div class="overview-stat">
						<div class="overview-num">75<em>%</em></div>
						<div class="overview-stat-label">Setup time reduction</div>
					</div>
					<div class="overview-stat">
						<div class="overview-num">40<em>%</em></div>
						<div class="overview-stat-label">First-time completion rate increase</div>
					</div>
					<div class="overview-stat">
						<div class="overview-num">10K<em>+</em></div>
						<div class="overview-stat-label">Active Players</div>
					</div>
				</div>
			</section>
			<!-- CONTEXT -->
			<section class="section reveal" id="s-context">
				<div class="section-head">
					<span class="section-title">Context</span>
				</div>
				<div class="context-two-col">
					<div class="context-block">
						<div class="context-q">What is FF VI</div>
						<p class="context-text">Final Fantasy is a Japanese sci-fi, anthology, role playing video game series with more than 173 million copies sold, making it one of the best selling game franchises of all time.</p>
						<p class="context-text">We are focusing on the 6th main installment (FFVI) which was released in 1994 for the Super Nintendo Entertainment System (SNES).</p>
					</div>
					<div class="context-block">
						<div class="context-q">What is a Randomizer?</div>
						<p class="context-text">A randomizer is a modification that shuffles game content to create unique experiences.</p>
						<p class="context-text">By rearranging item locations, enemy placements, and other elements, players can enjoy their favorite game in an entirely new way, as each playthrough becomes unpredictable and fresh.</p>
					</div>
				</div>
			</section>


			<!-- ③ PAIN POINTS -->
			<section class="section reveal" id="s-pain">
				<div class="section-head">
					<span class="section-title">Pain Points</span>
					<span class="section-tag">Powerful for veterans. Impossible for newcomers.</span>
				</div>
				<p class="body-text pain-lead">The Randomizer lets FF6 fans customize characters, combat, and rewards. But 200+ settings with no guidance meant newcomers quit before their first run.</p>
				<div class="pain-list">
					<div class="pain-item">
						<span class="pain-num">01</span>
						<div>
							<div class="pain-title">New players couldn't get started</div>
							<p class="body-text">No onboarding, no context — just 200+ settings on an unfamiliar screen.</p>
						</div>
					</div>
					<div class="pain-item">
						<span class="pain-num">02</span>
						<div>
							<div class="pain-title">The community couldn't grow</div>
							<p class="body-text">The complexity barrier kept passionate FF6 fans from reconnecting with a tool built for them.</p>
						</div>
					</div>
				</div>
				<img src="/images/ff6-pain.gif" alt="Original FF6 Randomizer UI" class="pain-img" />
			</section>

			<!-- ④ SOLUTION -->
			<div class="sol-group">
			<section class="section reveal" id="s-solution">
				<div class="section-head">
					<span class="section-title">Solution</span>
				</div>

				<!-- Featured decision -->
				<div class="sol-row sol-row-featured">
					<div class="sol-tag">3-Minute Tutorial</div>
					<div class="sol-title">Meet Terra — your guide through the settings</div>
					<p class="body-text sol-featured-body">200+ settings with no starting point meant most new players never got past the first screen. We introduced Terra, FF6's protagonist, as an onboarding guide. She walks through key settings step by step, with a progress bar so players always know where they are. Skip it anytime. No external wiki, no guesswork.</p>
					<img src="/images/3min.gif" alt="Terra tutorial walkthrough" class="sol-row-img sol-gif" />
				</div>

				<!-- Other key decisions grid -->
				<div class="other-decisions">
					<div class="other-decisions-head">Other key decisions</div>
					<div class="decision-grid">
						<div class="decision-card">
							<img src="/images/ff6-basic-advanced.png" alt="Basic / Advanced Mode" class="decision-hover-img" />
							<div class="decision-card-content">
								<div class="decision-title">Basic / Advanced Mode</div>
								<div class="decision-sub">Hide complexity until players are ready</div>
								<p class="decision-text">Basic mode shows only essential settings. Advanced unlocks all 200+. Players switch anytime — no commitment required.</p>
							</div>
						</div>
						<div class="decision-card">
							<img src="/images/ff6-tooltips.png" alt="Hover Tooltips" class="decision-hover-img" />
							<div class="decision-card-content">
								<div class="decision-title">Hover Tooltips</div>
								<div class="decision-sub">Definitions where decisions happen</div>
								<p class="decision-text">Each setting has a tooltip with a plain-language definition and an animated GIF showing exactly what it changes in-game.</p>
							</div>
						</div>
						<div class="decision-card">
							<img src="/images/ff6-seeds.png" alt="Saved Seeds &amp; Presets" class="decision-hover-img" />
							<div class="decision-card-content">
								<div class="decision-title">Saved Seeds &amp; Presets</div>
								<div class="decision-sub">Pick up where you left off</div>
								<p class="decision-text">Save any configuration as a named preset, share it with the community, or return to it later.</p>
							</div>
						</div>
						<div class="decision-card">
							<img src="/images/ff6-guest.png" alt="Guest Entry" class="decision-hover-img" />
							<div class="decision-card-content">
								<div class="decision-title">Guest Entry</div>
								<div class="decision-sub">No registration required</div>
								<p class="decision-text">Skip straight to randomization without creating an account — sign in only when you want to save.</p>
							</div>
						</div>
						<div class="decision-card">
							<img src="/images/ff6-nav.png" alt="Persistent Navigation" class="decision-hover-img" />
							<div class="decision-card-content">
								<div class="decision-title">Persistent Navigation</div>
								<div class="decision-sub">All settings always visible</div>
								<p class="decision-text">Settings live in a persistent left panel so players always know what's available and where they are.</p>
							</div>
						</div>
						<div class="decision-card">
							<img src="/images/ff6-export.png" alt="Export &amp; Confirmation" class="decision-hover-img" />
							<div class="decision-card-content">
								<div class="decision-title">Export &amp; Confirmation</div>
								<div class="decision-sub">Review before you play</div>
								<p class="decision-text">A full summary of all changes before uploading to the emulator — tutorial stays accessible in the corner.</p>
							</div>
						</div>
					</div>
				</div>

			</section>
			</div><!-- end .sol-group -->

			<!-- ⑨ RESEARCH -->
			<section class="section reveal" id="s-research">
				<div class="section-head">
					<span class="section-title">Design Process</span>
					<span class="section-tag">How did we get here?</span>
				</div>
				<p class="body-text" style="max-width:55ch;margin-bottom:2.5rem">My approach: understand both game &amp; community.</p>
				<div class="research-steps">
					<div class="step-card">
						<span class="step-num">01 — Comparative Analysis</span>
						<div class="step-title">Studying other randomizers</div>
						<p class="step-text">We analyzed randomizers from Final Fantasy 4 and other RPGs to identify best practices.</p>
					</div>
					<div class="step-card">
						<span class="step-num">02 — Community Immersion</span>
						<div class="step-title">Inside the community</div>
						<p class="step-text">We joined Discord channels, watched Twitch streams, and played FF6 to understand player motivations.</p>
					</div>
					<div class="step-card">
						<span class="step-num">03 — User Surveys</span>
						<div class="step-title">24 community responses</div>
						<p class="step-text">We distributed surveys on Discord's main FF6 channel, receiving 24 responses from community members.</p>
					</div>
					<div class="step-card">
						<span class="step-num">04 — Contextual Interviews</span>
						<div class="step-title">Randomizer &amp; casual players</div>
						<p class="step-text">We conducted interviews with randomizer experienced users, FF6 players, and gaming enthusiasts.</p>
					</div>
				</div>
				<figure class="research-figure">
					<img src="/images/ff6-journey-map.png" alt="FF6 Worlds Collide user journey map" class="research-img" />
					<figcaption class="research-caption">User journey map across three phases. Pain points surfaced consistently: players felt overwhelmed with no clear starting point, isolated when joining a community they didn't understand, and frustrated by a randomizer that assumed prior knowledge — with no guidance, no onboarding, and no obvious reason to push through.</figcaption>
				</figure>
			</section>

			<!-- ⑩ TOP 5 USER COMPLAINTS -->
			<div class="full-group fg-complaints" id="fg-complaints">
			<section class="section reveal" id="s-complaints">
				<div class="section-head">
					<span class="section-title">Top 5 User Complaints</span>
				</div>
				<div class="complaint-list">
					<div class="line-fill" id="lineFill"></div>
					<div class="complaint-item">
						<span class="complaint-num">01</span>
						<div class="complaint-body">
							<div class="complaint-title">Overwhelming options</div>
							<p class="complaint-text">Players encountered hundreds of customizable settings with no guidance on where to start or what options meant.</p>
							<figure class="complaint-figure">
								<img src="/images/ff6-overwhelming.png" alt="FF6 Randomizer settings — hundreds of options with no guidance" class="complaint-img" />
							</figure>
						</div>
					</div>
					<div class="complaint-item">
						<span class="complaint-num">02</span>
						<div class="complaint-body">
							<div class="complaint-title">Hidden knowledge</div>
							<p class="complaint-text">Users had to constantly switch between the randomizer, Wiki pages, and YouTube tutorials to understand terminology.</p>
							<figure class="complaint-figure">
								<img src="/images/ff6-wiki.png" alt="Worlds Collide Wiki — the external resource players had to rely on" class="complaint-img" />
							</figure>
							<div class="hmw-block">
								<span class="hmw-num">HMW 01</span>
								<div class="hmw-text">How might we educate without overwhelming players eager to start?</div>
							</div>
							<div class="need-row"><span class="need-dot"></span>New Users need clear explanations of terms</div>
							<div class="need-row"><span class="need-dot"></span>Experienced Players want quick access to advanced settings</div>
							<div class="need-row"><span class="need-dot"></span>Tournament Organizers need consistent difficulty presets</div>
							<div class="need-row"><span class="need-dot"></span>Streamers need to generate seeds quickly</div>
						</div>
					</div>
					<div class="complaint-item">
						<span class="complaint-num">03</span>
						<div class="complaint-body">
							<div class="complaint-title">Analysis paralysis</div>
							<p class="complaint-text">Players had to understand all settings before generating their first game, unable to start playing without extensive research.</p>
							<div class="hmw-block">
								<span class="hmw-num">HMW 02</span>
								<div class="hmw-text">How might we balance quick start accessibility with deep customization?</div>
							</div>
							<div class="need-row"><span class="need-dot"></span>Quick-Start Users want to play immediately</div>
							<div class="need-row"><span class="need-dot"></span>Customization Enthusiasts want granular control</div>
						</div>
					</div>
					<div class="complaint-item">
						<span class="complaint-num">04</span>
						<div class="complaint-body">
							<div class="complaint-title">Cryptic flag strings</div>
							<p class="complaint-text">Players could save settings as text strings (flags), but these cryptic codes like <code>-cg -oa 2.2.2.2.6.6.4.9.9</code> were impossible to understand without decoding.</p>
						</div>
					</div>
					<div class="complaint-item">
						<span class="complaint-num">05</span>
						<div class="complaint-body">
							<div class="complaint-title">Blind configuration</div>
							<p class="complaint-text">Players selected settings through abstract flags without seeing a consolidated view of what their choices actually created.</p>
							<figure class="complaint-figure">
								<img src="/images/ff6-generate.png" alt="FF6 Randomizer generate page showing a wall of cryptic flag strings" class="complaint-img" />
							</figure>
							<div class="hmw-block">
								<span class="hmw-num">HMW 03</span>
								<div class="hmw-text">How might we help players understand and verify their choices before committing?</div>
							</div>
							<div class="need-row"><span class="need-dot"></span>New users and other user groups are finally on the same side!</div>
						</div>
					</div>
				</div>
			</section>
			</div><!-- end fg-complaints -->

			<!-- ⑪ DESIGN SOLUTIONS -->
			<section class="section reveal" id="s-designsol">
				<div class="section-head">
					<span class="section-title">Design Solutions</span>
				</div>
				<div class="hmw-block">
					<span class="hmw-num">HMW 01</span>
					<div class="hmw-text">How might we educate without overwhelming players eager to start?</div>
				</div>
				<div class="key-grid">
					<div class="key-grid-item">
						<div class="key-label">Key Decision</div>
						<p class="key-text">Through interviews, I discovered players respond to game-world elements. I proposed using Terra, FF6's protagonist, to guide users through a 3-minute interactive tutorial that explains settings while maintaining immersion.</p>
					</div>
					<div class="key-grid-item">
						<div class="key-label">Key Decision</div>
						<p class="key-text">Rather than front-loading all information, I designed hover tooltips next to each setting. When clicked, tooltips show the term definition plus animated GIFs demonstrating how the setting affects gameplay.</p>
					</div>
				</div>
				<figure class="sol-full-figure">
					<img src="/images/ff6-settings.gif" alt="FF6 Worlds Collide redesign — settings interface with Terra tutorial overlay" class="sol-full-img" />
				</figure>
				<div class="hmw-block">
					<span class="hmw-num">HMW 02</span>
					<div class="hmw-text">How might we balance quick-start accessibility with deep customization?</div>
				</div>
				<div class="sol-row">
					<div class="sol-row-text">
						<div><div class="key-label">Key Decision</div></div>
						<p class="key-text">We created two interface modes: Basic shows essential settings while Advanced reveals all 200+ options. Players can switch between modes anytime, gradually exploring deeper customization as they gain confidence.</p>
					</div>
					<video
						src="/images/ff6-intro.mov"
						class="sol-row-img sol-video"
						autoplay loop muted playsinline
					></video>
				</div>
				<div class="hmw-block">
					<span class="hmw-num">HMW 03</span>
					<div class="hmw-text">How might we make saved configurations meaningful and reusable?</div>
				</div>
				<div class="key-grid">
					<div class="key-grid-item">
						<div class="key-label">Key Decision</div>
						<p class="key-text">Instead of a flat list, I grouped settings by categories (Party, SwdTechs, Blitzes, Lores, Commands, Characters). Yellow highlights emphasize modified values, making customizations immediately visible among default settings.</p>
					</div>
					<div class="key-grid-item">
						<div class="key-label">Key Decision</div>
						<p class="key-text">Users can now save their settings as named presets, revisit them at any time, and share seed configurations with the community.</p>
					</div>
				</div>
				<figure class="sol-full-figure">
					<img src="/images/ff6-settings.gif" alt="FF6 Worlds Collide redesign — profile page with presets and history of seed" class="sol-full-img" />
				</figure>
			</section>

			<!-- ⑫ REFLECTION -->
			<section class="section reveal" id="s-reflection">
				<div class="section-head">
					<span class="section-title">Reflection</span>
					<span class="section-tag">Constraints &amp; Takeaways</span>
				</div>
				<div class="constraint-grid">
					<div class="constraint-card">
						<span class="constraint-label">Constraint</span>
						<div class="constraint-title">Limited domain knowledge</div>
						<p class="constraint-text">None of our team had FF6 experience. This constraint became a strength — we conducted extensive interviews and usability tests, ensuring designs reflected actual user needs rather than designer assumptions.</p>
					</div>
					<div class="constraint-card">
						<span class="constraint-label">Constraint</span>
						<div class="constraint-title">Community access barriers</div>
						<p class="constraint-text">FF6 players exist in niche Discord channels and forums. I learned to build trust by genuinely engaging with the community — playing the game, watching streams, and participating in discussions before requesting interviews.</p>
					</div>
					<div class="constraint-card">
						<span class="constraint-label">Takeaway</span>
						<div class="constraint-title">Communities value authenticity over polish</div>
						<p class="constraint-text">Using Terra as the tutorial guide and maintaining FF6's aesthetic proved more effective than modern UI patterns. I learned to respect existing community culture rather than impose external design standards.</p>
					</div>
				</div>
				<div class="section-head ai-sub-head">
					<span class="section-tag">What Would I Do Different Now With AI?</span>
				</div>
				<div class="ai-grid">
					<div class="ai-card">
						<div class="ai-title">Compress the learning curve</div>
						<p class="ai-text">Understand game mechanics in days, not weeks — feed FF6 documentation to AI for instant summaries and glossaries instead of manually reading wikis for hours.</p>
					</div>
					<div class="ai-card">
						<div class="ai-title">Automate research synthesis</div>
						<p class="ai-text">Turn interview analysis from hours to minutes — let AI identify patterns and pull quotes from transcripts. Focus on insights, not organizing sticky notes.</p>
					</div>
					<div class="ai-card">
						<div class="ai-title">Test before recruiting users</div>
						<p class="ai-text">Catch obvious issues with AI personas — simulate confused newbies and impatient experts to stress-test designs before real usability sessions. More time for strategy and user empathy. Less time on repetitive tasks.</p>
					</div>
				</div>
			</section>

			<!-- BOTTOM NAV + FOOTER — full-width -->
			<div class="full-group fg-bottom" id="fg-bottom">
				<div class="case-nav reveal">
					<a href="/works" class="case-nav-item">
						<span class="case-nav-label">← Back</span>
						<span class="case-nav-title">All Work</span>
					</a>
					<a href="/works/slcc-flooring" class="case-nav-item" style="text-align:right">
						<span class="case-nav-label">Next Project →</span>
						<span class="case-nav-title">SLCC Flooring Website Revamp</span>
					</a>
				</div>
			</div><!-- end fg-bottom -->

			<div class="footer-wrap">
				<Footer />
			</div>

		</div><!-- end main-content -->
	</div><!-- end page-wrapper -->

	<script>
		// Cursor
		const cursor = document.getElementById('cursor') as HTMLElement;
		const ring   = document.getElementById('ring') as HTMLElement;
		document.body.style.cursor = 'none';
		document.addEventListener('mousemove', e => {
			cursor.style.left = e.clientX + 'px'; cursor.style.top = e.clientY + 'px';
			ring.style.left   = e.clientX + 'px'; ring.style.top   = e.clientY + 'px';
		});
		document.querySelectorAll<HTMLElement>('a, .pain-card, .step-card, .constraint-card, .ai-card').forEach(el => {
			el.addEventListener('mouseenter', () => { cursor.style.width='18px'; cursor.style.height='18px'; cursor.style.opacity='.5'; ring.style.width='52px'; ring.style.height='52px'; });
			el.addEventListener('mouseleave', () => { cursor.style.width='8px';  cursor.style.height='8px';  cursor.style.opacity='1';  ring.style.width='32px'; ring.style.height='32px'; });
		});

		// Side nav scroll spy
		const sections = document.querySelectorAll<HTMLElement>('[id^="s-"]');
		const navLinks = document.querySelectorAll<HTMLElement>('.side-nav-item[href]');
		const scrollSpy = new IntersectionObserver(entries => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const id = entry.target.id;
					navLinks.forEach(link => {
						link.classList.remove('active');
						if (link.getAttribute('href') === '#' + id) link.classList.add('active');
					});
				}
			});
		}, { rootMargin: '-20% 0px -70% 0px' });
		sections.forEach(s => scrollSpy.observe(s));
		navLinks.forEach(link => {
			link.addEventListener('click', e => {
				e.preventDefault();
				const target = document.querySelector(link.getAttribute('href') as string);
				if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
			});
		});

		// Complaint line — continuous scroll-driven fill
		const complaintList  = document.querySelector<HTMLElement>('.complaint-list');
		const lineFill       = document.getElementById('lineFill') as HTMLElement;
		const complaintItems = Array.from(document.querySelectorAll<HTMLElement>('#s-complaints .complaint-item'));
		const LINE_START_PX  = 3.2 * 16;
		const BULLET_OFFSET  = 3   * 16;
		const TRIGGER        = 0.5; // bullet "reached" when it crosses viewport centre

		const updateComplaintLine = () => {
			if (!complaintList || !lineFill) return;
			const triggerY = window.innerHeight * TRIGGER;
			const bullets  = complaintItems.map(item => ({
				vY:   item.getBoundingClientRect().top + BULLET_OFFSET,
				lY:   item.offsetTop + BULLET_OFFSET,
				item,
			}));

			let fillHeight = 0;
			for (let i = 0; i < bullets.length; i++) {
				const curr = bullets[i];
				const next = bullets[i + 1];
				if (curr.vY <= triggerY) {
					curr.item.classList.add('line-active');
					if (!next) {
						// last item — interpolate from bullet to bottom of list at same speed
						const D = complaintList.offsetHeight - curr.lY;
						const t = D > 0 ? Math.min(1, (triggerY - curr.vY) / D) : 1;
						fillHeight = curr.lY - LINE_START_PX + t * D;
						if (t >= 1) complaintList.classList.add('line-end');
						else complaintList.classList.remove('line-end');
					} else {
						fillHeight = curr.lY - LINE_START_PX;
						if (next.vY > triggerY) {
							// interpolate continuously between this bullet and the next
							const D = next.lY - curr.lY;
							const t = D > 0 ? (triggerY - curr.vY) / D : 0;
							fillHeight = curr.lY - LINE_START_PX + t * D;
						}
					}
				}
			}
			lineFill.style.height = Math.max(0, fillHeight) + 'px';
		};
		window.addEventListener('scroll', updateComplaintLine, { passive: true });
		updateComplaintLine();

		// Side nav — scroll-driven fade as fg-bottom approaches
	const sideNavEl   = document.getElementById('sideNav') as HTMLElement;
	const fadeAnchor  = document.querySelector<HTMLElement>('.fg-bottom');
	const updateNavOpacity = () => {
		if (!sideNavEl || !fadeAnchor) return;
		const footerTop = fadeAnchor.getBoundingClientRect().top;
		const fadeStart = window.innerHeight;       // fg-bottom enters viewport → start fading
		const fadeEnd   = window.innerHeight * 0.5; // fg-bottom at nav centre → fully hidden
		if (footerTop >= fadeStart) {
			sideNavEl.style.removeProperty('opacity');
			sideNavEl.style.pointerEvents = '';
		} else {
			const t = Math.max(0, Math.min(1, (footerTop - fadeEnd) / (fadeStart - fadeEnd)));
			sideNavEl.style.setProperty('opacity', String(t), 'important');
			sideNavEl.style.pointerEvents = t < 0.05 ? 'none' : '';
		}
	};
	window.addEventListener('scroll', updateNavOpacity, { passive: true });
	updateNavOpacity();

	// Reveal on scroll
		const obs = new IntersectionObserver(entries => {
			entries.forEach(e => {
				if (e.isIntersecting) {
					requestAnimationFrame(() => e.target.classList.add('in'));
					obs.unobserve(e.target);
				}
			});
		}, { threshold: 0.05 });
		document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
	</script>
</body>
</html>

