						<div class="skill-group-label">Tools</div>
						<div class="skill-group-title">Tools and Tech</div>
						<div class="skill-list">
							<div class="skill-item">Figma / FigJam</div>
							<div class="skill-item">Adobe Creative Suite</div>
							<div class="skill-item">Miro</div>
							<div class="skill-item">Notion / Confluence</div>
							<div class="skill-item">HTML / CSS / JavaScript</div>
							<div class="skill-item">Python</div>
							<div class="skill-item">Unity</div>
							<div class="skill-item">Agile and Scrum</div>
							<div class="skill-item">Design Thinking Facilitation</div>
						</div>
					</div>
				</div>
				<div class="skill-group skill-group-ai">
					<div class="skill-group-label">AI</div>
					<div class="skill-group-title">AI &amp; Emerging Tech</div>
					<div class="ai-current">
						<span class="ai-current-dot"></span>
						Currently building an AI agent for SLCC Flooring to automate front-desk operations
					</div>
					<div class="skill-list">
						<div class="skill-item">Human-AI Interaction Design</div>
						<div class="skill-item">Prompt Engineering</div>
						<div class="skill-item">Conversational UI / Chatbot Design</div>
						<div class="skill-item">AI-assisted Design Workflows</div>
						<div class="skill-item">LLM Integration and API</div>
						<div class="skill-item">Generative AI Tools (Midjourney, DALL·E)</div>
						<div class="skill-item">AI Ethics and Responsible Design</div>
						<div class="skill-item">Data Literacy and AI Output Evaluation</div>
					</div>
				</div>
			</section>

			<!-- AVAILABILITY -->
			<div class="proj-nav reveal">
				<a href="/works/slcc-flooring" class="proj-nav-cell proj-nav-left">
					<span class="proj-nav-label">← Project</span>
					<span class="proj-nav-title">SLCC Flooring Website Revamp</span>
				</a>
				<a href="/works/ff6-randomizer" class="proj-nav-cell proj-nav-right">
					<span class="proj-nav-label">Project →</span>
					<span class="proj-nav-title">FF6 Worlds Collide Randomizer</span>
