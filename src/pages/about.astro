		</div>
	</div>

	<Footer />

	<script>
		const cursor = document.getElementById('cursor') as HTMLElement;
		const ring   = document.getElementById('ring') as HTMLElement;
		document.body.style.cursor = 'none';
		document.addEventListener('mousemove', e => {
			cursor.style.left = e.clientX + 'px'; cursor.style.top = e.clientY + 'px';
			ring.style.left   = e.clientX + 'px'; ring.style.top   = e.clientY + 'px';
		});
		document.querySelectorAll<HTMLElement>('a, .edu-card, .skill-group, .philosophy-card, .interest-card').forEach(el => {
			el.addEventListener('mouseenter', () => { cursor.style.width='18px'; cursor.style.height='18px'; cursor.style.opacity='0.5'; ring.style.width='52px'; ring.style.height='52px'; });
			el.addEventListener('mouseleave', () => { cursor.style.width='8px';  cursor.style.height='8px';  cursor.style.opacity='1';   ring.style.width='32px'; ring.style.height='32px'; });
		});

		// Accordion
		document.querySelectorAll<HTMLElement>('.exp-header').forEach(header => {
			header.addEventListener('click', () => {
				const item = header.parentElement as HTMLElement;
				const body = item.querySelector<HTMLElement>('.exp-body')!;
				const isOpen = item.classList.contains('open');

				// Close all
				document.querySelectorAll<HTMLElement>('.exp-item').forEach(i => {
					i.classList.remove('open');
					(i.querySelector('.exp-body') as HTMLElement).style.maxHeight = '0';
				});

				// Open clicked if it was closed
				if (!isOpen) {
					item.classList.add('open');
					body.style.maxHeight = body.scrollHeight + 'px';
				}
			});
		});

		// Side nav scroll spy
		const sections = document.querySelectorAll('[id^="s-"]');
		const navLinks = document.querySelectorAll<HTMLElement>('.side-nav-item[href]');
		const scrollSpy = new IntersectionObserver(entries => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const id = entry.target.id;
					navLinks.forEach(link => {
						link.classList.remove('active');
						if (link.getAttribute('href') === '#' + id) link.classList.add('active');
					});
				}
			});
		}, { rootMargin: '-20% 0px -70% 0px' });
		sections.forEach(s => scrollSpy.observe(s));

		navLinks.forEach(link => {
			link.addEventListener('click', e => {
				e.preventDefault();
				const target = document.querySelector(link.getAttribute('href')!);
				if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
			});
		});

		// Interest card hover images — styles inlined to bypass Astro CSS scoping
	const floatEl = document.createElement('div');
	const floatImg = document.createElement('img');
	floatImg.alt = '';
	Object.assign(floatImg.style, {
		width: '100%', height: '200px', objectFit: 'cover', display: 'block',
	});
	floatEl.appendChild(floatImg);
	Object.assign(floatEl.style, {
		position: 'fixed', top: '0', left: '0',
		width: '260px',
		pointerEvents: 'none',
		zIndex: '9999',
		borderRadius: '10px',
		overflow: 'hidden',
		opacity: '0',
		transform: 'translate(-50%, -66%) scale(0.88) rotate(-2deg)',
		transition: 'opacity 0.35s ease, transform 0.35s cubic-bezier(0.16,1,0.3,1)',
		boxShadow: '0 20px 60px rgba(0,0,0,0.15)',
	});
	document.body.appendChild(floatEl);

	let tx = 0, ty = 0, cx = 0, cy = 0;

	document.querySelectorAll<HTMLElement>('.interest-card[data-hover-img]').forEach(card => {
		card.addEventListener('mouseenter', () => {
			floatImg.src = card.dataset.hoverImg!;
			floatEl.style.opacity = '1';
			floatEl.style.transform = 'translate(-50%, -66%) scale(1) rotate(0deg)';
		});
		card.addEventListener('mousemove', e => {
			tx = e.clientX;
			ty = e.clientY;
		});
		card.addEventListener('mouseleave', () => {
			floatEl.style.opacity = '0';
			floatEl.style.transform = 'translate(-50%, -66%) scale(0.88) rotate(-2deg)';
		});
	});

	const lerpF = (a: number, b: number, t: number) => a + (b - a) * t;
	(function floatTick() {
		cx = lerpF(cx, tx, 0.12);
		cy = lerpF(cy, ty, 0.12);
		floatEl.style.left = cx + 'px';
		floatEl.style.top  = cy + 'px';
		requestAnimationFrame(floatTick);
	})();

	// Reveal on scroll
		const obs = new IntersectionObserver(entries => {
			entries.forEach(e => {
				if (e.isIntersecting) {
					requestAnimationFrame(() => e.target.classList.add('in'));
					obs.unobserve(e.target);
				}
			});
		}, { threshold: 0.05 });
		document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

	</script>
</body>
</html>

<style>
	/* ── Layout ── */
	.page-wrapper {
		display: grid;
		grid-template-columns: 1fr 160px;
		min-height: 100vh;
		padding: 5rem 7rem 0;
	}
	.main-content { min-width: 0; order: 1; }
	.side-nav-col  { position: relative; order: 2; }

	.side-nav {
		position: sticky;
		top: 50vh;
		height: fit-content;
		transform: translateY(-50%);
		padding-left: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0;
		opacity: 0;
		animation: fadeIn 1s ease 1.2s forwards;
	}
	.side-nav-group { display: flex; flex-direction: column; gap: .2rem; }
	.side-nav-item {
		font-size: 0.875rem;
		letter-spacing: .08em;
		text-transform: uppercase;
		color: var(--muted);
		text-decoration: none;
		padding: .35rem 0 .35rem .8rem;
		border-left: 1px solid transparent;
		transition: color .25s, border-color .25s;
		line-height: 1.4;
		white-space: nowrap;
	}
	.side-nav-item:hover { color: var(--text); }
	.side-nav-item.active { color: var(--accent); border-left-color: var(--accent); }

	/* ── Hero ── */
	.hero {
		padding: 5rem 0 0;
		opacity: 0;
		animation: fadeUp .9s cubic-bezier(.16,1,.3,1) .4s forwards;
	}
	.hero-eyebrow { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; }
	.hero-eyebrow-line { width: 28px; height: 1px; background: var(--accent); }
	.hero-eyebrow span { font-size: 0.875rem; letter-spacing: .18em; text-transform: uppercase; color: var(--accent); }
	.hero-grid {
		display: grid;
