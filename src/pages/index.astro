---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="June — UX & Product Designer" description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="cursor" id="cursor"></div>
		<div class="cursor-ring" id="ring"></div>

		<Header />

		<!-- ─── HERO ─── -->
		<section class="hero">
			<div class="hero-main">
				<div class="hero-intro">
					<p class="hero-line-1">Hi, I am <em>June.</em></p>
					<p class="hero-line-2">I am a designer and researcher at UC Berkeley, working at the intersection of AI and human experience. Complexity is a given. Clarity is the job.</p>
					<p class="hero-bio">UX Research / AI Interfaces / End to End Design</p>
				</div>

				<div class="hero-actions">
					<a href="#works" class="btn btn-fill">View Work ↓</a>
					<a href="/about" class="btn btn-outline">About me →</a>
				</div>

			</div>
		</section>

		<!-- ─── SKILL TICKER ─── -->
		<div class="ticker-wrap" id="ticker-wrap">
			<div class="ticker-track" id="ticker-track">
				<div class="ticker-seg">
					<span class="t-word">WIREFRAMING</span><span class="t-dot">·</span>
					<span class="t-word t-hi">VISUAL DESIGN</span><span class="t-dot">·</span>
					<span class="t-word">DESIGN SYSTEMS</span><span class="t-dot">·</span>
					<span class="t-word t-hi">INFORMATION ARCHITECTURE</span><span class="t-dot">·</span>
					<span class="t-word">ACCESSIBILITY WCAG</span><span class="t-dot">·</span>
					<span class="t-word t-hi">HEURISTIC EVALUATION</span><span class="t-dot">·</span>
					<span class="t-word">CARD SORTING</span><span class="t-dot">·</span>
					<span class="t-word t-hi">USABILITY TESTING</span><span class="t-dot">·</span>
					<span class="t-word">USER INTERVIEWS</span><span class="t-dot">·</span>
					<span class="t-word t-hi">PROTOTYPING</span><span class="t-dot">·</span>
					<span class="t-word">INTERACTION DESIGN</span><span class="t-dot">·</span>
					<span class="t-word t-hi">AI UX DESIGN</span><span class="t-dot">·</span>
					<span class="t-word">JOURNEY MAPPING</span><span class="t-dot">·</span>
					<span class="t-word t-hi">PRODUCT STRATEGY</span><span class="t-dot">·</span>
					<span class="t-word">RESEARCH SYNTHESIS</span><span class="t-dot">·</span>
					<span class="t-word t-hi">RESPONSIVE DESIGN</span><span class="t-dot">·</span>
				</div>
				<div class="ticker-seg" aria-hidden="true">
					<span class="t-word">WIREFRAMING</span><span class="t-dot">·</span>
					<span class="t-word t-hi">VISUAL DESIGN</span><span class="t-dot">·</span>
					<span class="t-word">DESIGN SYSTEMS</span><span class="t-dot">·</span>
					<span class="t-word t-hi">INFORMATION ARCHITECTURE</span><span class="t-dot">·</span>
					<span class="t-word">ACCESSIBILITY WCAG</span><span class="t-dot">·</span>
					<span class="t-word t-hi">HEURISTIC EVALUATION</span><span class="t-dot">·</span>
					<span class="t-word">CARD SORTING</span><span class="t-dot">·</span>
					<span class="t-word t-hi">USABILITY TESTING</span><span class="t-dot">·</span>
					<span class="t-word">USER INTERVIEWS</span><span class="t-dot">·</span>
					<span class="t-word t-hi">PROTOTYPING</span><span class="t-dot">·</span>
					<span class="t-word">INTERACTION DESIGN</span><span class="t-dot">·</span>
					<span class="t-word t-hi">AI UX DESIGN</span><span class="t-dot">·</span>
					<span class="t-word">JOURNEY MAPPING</span><span class="t-dot">·</span>
					<span class="t-word t-hi">PRODUCT STRATEGY</span><span class="t-dot">·</span>
					<span class="t-word">RESEARCH SYNTHESIS</span><span class="t-dot">·</span>
					<span class="t-word t-hi">RESPONSIVE DESIGN</span><span class="t-dot">·</span>
				</div>
			</div>
		</div>

		<!-- ─── PROJECTS ─── -->
		<section class="section" id="works">
			<div class="section-head">
				<span class="section-title">Selected Work</span>
				<span class="section-num">{projects.length} projects</span>
			</div>
			<div class="proj-grid">
				{projects.map((project, i) => (
					project.data.comingSoon ? (
						<div class="proj-card proj-card-soon" style={`--i:${i}`}>
							<div class="proj-img-wrap">
								{project.data.image
									? <img src={project.data.image} alt={project.data.title} class="proj-img" loading="lazy" />
									: <div class="proj-img-fallback" style={`background:${project.data.color ?? '#F2EDE7'}`}></div>
								}
								<div class="proj-soon-overlay"><span class="proj-soon-pill">Coming Soon</span></div>
							</div>
							<div class="proj-body">
								<div class="proj-meta">
									<span class="proj-cat">{project.data.category}</span>
								</div>
								<div class="proj-title">{project.data.title}</div>
								<p class="proj-desc">{project.data.description}</p>
								<div class="proj-tags">{project.data.tags.map(t => <span class="proj-tag">{t}</span>)}</div>
							</div>
						</div>
					) : (
						<a href={`/works/${project.id}`} class="proj-card" style={`--i:${i}`}>
							<div class="proj-img-wrap">
								{project.data.image
									? <img src={project.data.image} alt={project.data.title} class="proj-img" loading="lazy" />
									: <div class="proj-img-fallback" style={`background:${project.data.color ?? '#F2EDE7'}`}></div>
								}
							</div>
							<div class="proj-body">
								<div class="proj-meta">
									<span class="proj-cat">{project.data.category}</span>
									{project.data.badge && (
										<span class="proj-badge"><span class="proj-badge-dot"></span>{project.data.badge}</span>
									)}
									<span class="proj-arrow">↗</span>
								</div>
								<div class="proj-title">{project.data.title}</div>
								<p class="proj-desc">{project.data.description}</p>
								<div class="proj-tags">{project.data.tags.map(t => <span class="proj-tag">{t}</span>)}</div>
							</div>
						</a>
					)
				))}
			</div>
		</section>

		<Footer />

		<script>
			// Cursor
			const cursor = document.getElementById('cursor') as HTMLElement;
			const ring   = document.getElementById('ring') as HTMLElement;
			document.body.style.cursor = 'none';

			document.addEventListener('mousemove', e => {
				cursor.style.left = e.clientX + 'px';
				cursor.style.top  = e.clientY + 'px';
				ring.style.left   = e.clientX + 'px';
				ring.style.top    = e.clientY + 'px';
			});

			document.querySelectorAll<HTMLElement>('a, .proj-card').forEach(el => {
				el.addEventListener('mouseenter', () => {
					cursor.style.width   = '18px';
					cursor.style.height  = '18px';
					cursor.style.opacity = '0.5';
					ring.style.width     = '52px';
					ring.style.height    = '52px';
				});
				el.addEventListener('mouseleave', () => {
					cursor.style.width   = '8px';
					cursor.style.height  = '8px';
					cursor.style.opacity = '1';
					ring.style.width     = '32px';
					ring.style.height    = '32px';
				});
			});

			// Scroll reveal — cards stagger in individually
			const obs = new IntersectionObserver(entries => {
				entries.forEach(e => {
					if (e.isIntersecting) {
						requestAnimationFrame(() => e.target.classList.add('in'));
						obs.unobserve(e.target);
					}
				});
			}, { threshold: 0.12 });
			document.querySelectorAll('.reveal, .proj-card').forEach(el => obs.observe(el));

		</script>
	</body>
</html>

<style>
	/* ─── SPACING TOKENS ─── */
	/* Outer gutter: 5rem desktop, 1.5rem mobile                  */
	/* Section vertical: 7rem desktop, 4rem mobile                */
	/* Card inner: 3rem desktop                                    */

	/* ─── HERO ─── */
	.hero {
		height: 100vh;
		display: flex;
		align-items: center;
		padding: 0 7rem;
	}
	.hero-main {
		display: flex;
		flex-direction: column;
		justify-content: center;
		width: 100%;
		gap: 0;                  /* use explicit margins below for fine control */
		opacity: 0;
		animation: fadeUp .9s cubic-bezier(.16,1,.3,1) .5s forwards;
	}

	/* Level 1 — tiny label */
	.hero-eyebrow {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 3rem;    /* large gap before hero text */
	}
	.hero-eyebrow-line { width: 28px; height: 1px; background: var(--accent); }
	.hero-eyebrow span {
		font-size: 0.75rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
	}

	/* Level 2 — dominant text */
	.hero-intro { margin-bottom: 3rem; }
	.hero-line-1 {
		font-family: var(--font-display);
		font-weight: 300;
		font-size: clamp(2.8rem, 6vw, 5.5rem);
		line-height: 1.0;
		letter-spacing: -0.02em;
		color: var(--text);
		margin-bottom: .25em;
	}
	.hero-line-1 em { font-style: italic; color: var(--accent); }
	.hero-line-2 {
		font-family: var(--font-display);
		font-weight: 300;
		font-size: clamp(1.35rem, 2.2vw, 1.9rem);
		line-height: 1.5;
		letter-spacing: -0.01em;
		color: var(--text);
	}
	.hero-bio {
		font-family: var(--font);
		font-size: 1rem;
		line-height: 1.8;
		color: var(--muted);
		margin-top: 2.5rem;
	}

	/* Level 3 — CTA row */
	.hero-actions {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 2rem;              /* horizontal, left-aligned under text */
	}
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		font-family: var(--font);
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		font-weight: 400;
		transition: gap .3s, color .3s, background .3s;
		text-decoration: none;
		white-space: nowrap;
	}
	.btn-fill {
		padding: 1rem 2.2rem;
		background: var(--text);
		color: var(--bg);
	}
	.btn-fill:hover { background: var(--accent); gap: 1.1rem; }
	.btn-outline {
		color: var(--muted);
		border-bottom: 1px solid var(--border);
		padding-bottom: 0.15rem;
	}
	.btn-outline:hover { color: var(--accent); border-color: var(--accent); gap: 1.1rem; }

	/* Hero bar — metadata strip at bottom of hero */
	.hero-bar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 2rem 0;
		border-top: 1px solid var(--border);
		margin-top: 5rem;
		opacity: 0;
		animation: fadeUp .8s ease 1.1s forwards;
	}
	.hero-bar-item { display: flex; flex-direction: column; gap: 0.5rem; }
	.hero-bar-label {
		font-size: 0.75rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--muted);
	}
	.hero-bar-value {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 400;
		color: var(--text);
	}
	.hero-bar-value em { font-style: italic; color: var(--accent); }
	.scroll-hint {
		display: flex;
		align-items: center;
		background: none;
		border: none;
		padding: 0;
		cursor: none;
	}
	.scroll-hint-line {
		width: 1px; height: 32px;
		background: var(--accent);
		animation: pulse-line 2s ease-in-out infinite;
	}

	/* ─── SKILL TICKER ─── */
	.ticker-wrap {
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		overflow: hidden;
		padding: 1.25rem 0;
		opacity: 0;
		animation: fadeUp .8s ease 1s forwards;
		position: relative;
	}
	.ticker-track {
		display: flex;
		width: max-content;
		animation: ticker-scroll 36s linear infinite;
	}
	.ticker-seg {
		display: flex;
		align-items: center;
	}
	.t-word {
		font-size: 0.75rem;
		letter-spacing: .15em;
		text-transform: uppercase;
		color: var(--muted);
		padding: 0 1.4rem;
		white-space: nowrap;
		display: inline-block;
	}
	.t-word.t-hi { color: var(--accent); }
	.t-dot {
		color: var(--accent);
		font-size: 0.75rem;
		flex-shrink: 0;
		opacity: 0.5;
	}
	@keyframes ticker-scroll {
		from { transform: translateX(0); }
		to   { transform: translateX(-50%); }
	}

	/* ─── SECTION SHELL ─── */
	.section { padding: 7rem; scroll-margin-top: 80px; }   /* matches navbar 7rem */

	/* Section label row: tiny uppercase title + count */
	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		border-bottom: 1px solid var(--border);
		padding-bottom: 1.25rem;
		margin-bottom: 0;
	}
	.section-title {
		font-size: 0.75rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--muted);
		font-weight: 400;
	}
	.section-num {
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		color: var(--muted);
		font-style: italic;
		font-family: var(--font-display);
	}

	/* ─── PROJECT GRID ─── */
	.proj-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem 2.5rem;
		margin-top: 3rem;
	}

	.proj-card {
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
		text-decoration: none;
		color: inherit;
		cursor: none;
		opacity: 0;
		transform: translateY(28px);
		transition:
			opacity  .7s ease         calc(var(--i, 0) * 0.13s),
			transform .7s cubic-bezier(.16,1,.3,1) calc(var(--i, 0) * 0.13s);
	}
	.proj-card.in          { opacity: 1; transform: translateY(0); }
	.proj-card-soon.in     { opacity: 0.58; }

	/* Image */
	.proj-img-wrap {
		position: relative;
		overflow: hidden;
		border-radius: 12px;
		aspect-ratio: 4/3;
		background: var(--bg2);
	}
	.proj-img {
		width: 100%; height: 100%;
		object-fit: contain;
		display: block;
		transform: scale(1.04);
		transition: transform .7s cubic-bezier(.16,1,.3,1);
	}
	.proj-card.in .proj-img           { transform: scale(1); }
	a.proj-card:hover .proj-img        { transform: scale(1.02); }
	.proj-img-fallback                 { width: 100%; height: 100%; }

	.proj-soon-overlay {
		position: absolute; inset: 0;
		display: flex; align-items: flex-start; padding: 1.25rem;
	}
	.proj-soon-pill {
		font-size: 0.7rem; letter-spacing: .14em; text-transform: uppercase;
		color: rgba(255,255,255,0.85);
		border: 1px solid rgba(255,255,255,0.35);
		background: rgba(0,0,0,0.18); backdrop-filter: blur(8px);
		padding: .25rem .75rem; border-radius: 999px;
	}

	/* Text body */
	.proj-body { display: flex; flex-direction: column; gap: .55rem; }
	.proj-meta { display: flex; align-items: center; gap: .75rem; }
	.proj-cat {
		font-size: 0.75rem; letter-spacing: .12em; text-transform: uppercase;
		color: var(--accent); flex: 1;
	}
	.proj-arrow {
		font-size: 1rem; color: var(--muted);
		transition: color .25s, transform .3s cubic-bezier(.16,1,.3,1);
	}
	a.proj-card:hover .proj-arrow { color: var(--accent); transform: rotate(45deg); }

	.proj-title {
		font-family: var(--font-display);
		font-weight: 300;
		font-size: clamp(1.35rem, 1.8vw, 1.9rem);
		color: var(--text); line-height: 1.2;
		transition: color .25s;
	}
	a.proj-card:hover .proj-title { color: var(--accent); }
	.proj-desc { font-size: 1rem; line-height: 1.65; color: var(--muted); }

	.proj-tags { display: flex; flex-wrap: wrap; gap: .35rem; margin-top: .15rem; }
	.proj-tag {
		font-size: 0.75rem; letter-spacing: .1em; text-transform: uppercase;
		color: var(--muted); border: 1px solid var(--border); padding: .2rem .6rem;
	}

	.proj-badge {
		display: inline-flex; align-items: center; gap: .35rem;
		background: rgba(251,153,102,.1); border: 1px solid rgba(251,153,102,.35);
		border-radius: 2rem; padding: .18rem .65rem;
		font-size: 0.7rem; letter-spacing: .1em; text-transform: uppercase; color: var(--accent);
	}
	.proj-badge-dot {
		width: 5px; height: 5px; background: var(--accent); border-radius: 50%;
		animation: pulse 2s ease-in-out infinite;
	}
	@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.8)} }


	/* ─── RESPONSIVE ─── */
	@media (max-width: 1100px) {
		.hero { padding: 0 3rem; padding-top: 8rem; }
		.section { padding: 6rem 3rem; }
	}
	@media (max-width: 900px) {
		.hero { padding: 0 2rem; padding-top: 7rem; }
		.section { padding: 5rem 2rem; }
	}
	@media (max-width: 900px) {
		.proj-grid { gap: 2.5rem 2rem; }
	}
	@media (max-width: 700px) {
		.hero { padding: 0 1.5rem; padding-top: 6.5rem; }
		.hero-actions { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
		.section { padding: 4rem 1.5rem; }
		.ticker-wrap { display: none; }
		.proj-grid { grid-template-columns: 1fr; gap: 3rem; }
	}
</style>
